# Rafael Coffee Backend — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

NODE_ENV=development
PORT=3001

# Database (auto-set by Railway in production)
DATABASE_URL=postgresql://user:password@localhost:5432/rafael_coffee

# Square
SQUARE_ACCESS_TOKEN=your_square_sandbox_access_token
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key

# Auth
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
